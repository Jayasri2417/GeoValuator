# Server environment variables
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/geovaluator?retryWrites=true&w=majority&appName=geovaluator
JWT_SECRET=replace_me
USE_MEMORY_DB=false
PORT=5000
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
GOOGLE_MAPS_API_KEY=your_google_maps_key
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# Deployment Settings
ALLOWED_ORIGINS=http://localhost:5173,https://geovaluator.vercel.app
PYTHON_AI_ENGINE_URL=http://localhost:5001

